{
  "name": "leetcode-tracker-server",
  "version": "2.0.0",
  "description": "Backend for LeetCode Tracker (AWS Serverless)",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "seed": "node src/db/seed-dynamodb.js",
    "package": "zip -r lambda-deploy.zip lambda.js lambda-backup.js lambda-autosync.js package.json package-lock.json node_modules/ src/ .env"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/lib-dynamodb": "^3.700.0",
    "axios": "^1.13.6",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "serverless-http": "^3.2.0",
    "uuid": "^11.1.0"
  }
}
